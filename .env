# Service Axum : plage 8200–8299 (services métier core). Défaut 8200.
PORT=8200

# docker-compose : les services sont sous les profils « dev » et « prod ».
# Sans profil, `docker compose up` ne démarre rien. Soit :
#   docker compose --profile prod up -d
#   docker compose --profile dev up
# soit définir ici (Compose lit ce fichier si copié en .env) :
# COMPOSE_PROFILES=prod

# PostgreSQL (exemple pour les profils dev/prod — adapter user/mot de passe/DB)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=rust-db-dev
